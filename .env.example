APP_NAME=TrackApp
APP_ENV=development
SECRET_KEY=
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/usps_tracker
BASE_URL=http://localhost:8000

# USPS production example. For TEM testing use https://apis-tem.usps.com
USPS_BASE_URL=https://apis.usps.com
USPS_OAUTH_PATH=/oauth2/v3/token
USPS_TRACKING_PATH_TEMPLATE=/tracking/v3/tracking/{tracking_number}
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

TRACKING_REFRESH_MINUTES=60
WORKER_POLL_SECONDS=45
