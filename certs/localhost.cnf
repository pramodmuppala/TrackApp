[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req

[dn]
C = US
ST = NY
L = New York
O = Local Dev
OU = Hita Apps
CN = localhost

[v3_req]
subjectAltName = @alt_names
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = localhost
DNS.2 = host.docker.internal
DNS.3 = trackapp
DNS.4 = invoiceapp
DNS.5 = frontendapp
IP.1 = 127.0.0.1
IP.2 = ::1
